# Etch WP API Credentials
# Copy this file to .env and fill in your credentials
# .env is gitignored - never commit credentials!

# WordPress Application Password Authentication
ETCH_API_USERNAME=your_username
ETCH_API_PASSWORD=your_application_password

# Optional: Development URL override
# If not set, uses devUrl from .etch-project.json
# ETCH_DEV_URL=https://your-site.de

# Optional: API Base URL override
# If not set, auto-generated from ETCH_DEV_URL or .etch-project.json
# ETCH_API_BASE_URL=https://your-site.de/wp-json/etch-api
